# Copy to .env and fill in your key. This is the ONLY auth source for the app.
# Get your key (it starts with "sk_live_") from https://getdial.ai
DIAL_API_KEY=sk_live_REPLACE_WITH_YOUR_DIAL_KEY

# Optional:
# PORT=8000
# DIAL_BASE_URL=https://getdial.ai
# DIAL_NUMBER_ID=          # default sending number id; falls back to your first number
