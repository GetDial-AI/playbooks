{
  "name": "dial-sms-voice-node",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Web dashboard to place AI voice calls and send/receive SMS with the Dial Node SDK (Express + ws).",
  "scripts": {
    "start": "node --import tsx --env-file-if-exists=.env server.ts",
    "dev": "node --import tsx --watch --env-file-if-exists=.env server.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@getdial/sdk": "^0.6.3",
    "express": "^5.2.1",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.2",
    "@types/ws": "^8.18.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
