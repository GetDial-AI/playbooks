# ── Dial ──────────────────────────────────────────────────────
# Your Dial API key. Get one at https://getdial.ai
DIAL_API_KEY=sk_live_REPLACE_WITH_YOUR_DIAL_KEY

# ── Agent LLM ─────────────────────────────────────────────────
# provider: fake | openai | openrouter
#   fake       -> scripted offline model, no key, no cost (great for testing wiring)
#   openai     -> real model via OpenAI
#   openrouter -> real model via OpenRouter (OpenAI API + different base_url)
LLM_PROVIDER=fake
LLM_MODEL=gpt-4o-mini

# For provider=openai:
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=                                  # optional custom endpoint

# For provider=openrouter (model e.g. anthropic/claude-3.5-sonnet, openai/gpt-4o-mini):
# OPENROUTER_API_KEY=sk-or-...
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
